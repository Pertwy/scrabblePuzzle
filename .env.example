# Copy to .env.local for local development.

# Base URL from AWS SAM stack output ApiEndpoint (no trailing slash).
# When set, puzzles load/save via API instead of localStorage.
# No spaces or trailing slash
REACT_APP_PUZZLES_API_URL=

# Optional: must match EditApiKey stack parameter (sent as X-Edit-Key on save).
REACT_APP_PUZZLES_EDIT_KEY=
